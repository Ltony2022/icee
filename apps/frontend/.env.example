# Used when the UI runs without Electron (e.g. Vite only) or to override defaults.
# Packaged Electron uses ICEE_BACKEND_HOST / ICEE_BACKEND_PORT from the main process via preload.

# Full API origin (optional; overrides host+port below)
# VITE_ICEE_BACKEND_ORIGIN=http://127.0.0.1:8000

# Or host + port (defaults: 127.0.0.1 and 8000 for dev and 8765 for production — same as apps/server/run_backend.py)
# VITE_ICEE_BACKEND_HOST=127.0.0.1
# VITE_ICEE_BACKEND_PORT=8000
